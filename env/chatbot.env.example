# --- Gemini API Key ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# --- Standard Chat Model ---
CHAT_MODEL=gemini-2.0-flash

# --- Gemini Live API ---
# Set to 1 to enable Gemini Live API mode (real-time voice)
USE_LIVE_API=0

# Live API model (see: https://ai.google.dev/gemini-api/docs/live)
LIVE_MODEL=gemini-2.0-flash-live-001

# Voice name: Puck, Charon, Kore, Fenrir, Aoede, Leda, Orus, Zephyr
LIVE_VOICE_NAME=Puck

# Response modality: AUDIO or TEXT
LIVE_RESPONSE_MODALITY=AUDIO

# Live mode: text_to_text, text_to_audio, mic_live
# - text_to_text: type text, get text response (uses Live API streaming)
# - text_to_audio: type text, get audio response from Gemini voice
# - mic_live: real-time microphone conversation (requires sounddevice)
LIVE_MODE=text_to_audio
